{
  "appName": "To-Do List",
  "startPage": "viewTasksPage",
  "menu": [
    { "label": "My Tasks", "mapsTo": "viewTasksPage" },
    { "label": "Add Task", "mapsTo": "addTaskPage" },
    { "label": "Mark Done", "mapsTo": "updateTaskPage" }
  ],
  "pages": {
    "addTaskPage": {
      "component": "page",
      "title": "Add a New Task",
      "content": [
        {
          "component": "text",
          "content": "Create a new task for your to-do list.",
          "styleHint": { "variant": "body" }
        },
        {
          "component": "form",
          "id": "addTaskForm",
          "fields": [
            { "name": "taskName", "label": "Task", "type": "text", "required": true, "placeholder": "e.g., Buy groceries" },
            { "name": "dueDate", "label": "Due Date", "type": "date" },
            { "name": "priority", "label": "Priority", "type": "select", "options": ["High", "Medium", "Low"], "default": "Medium" },
            { "name": "done", "label": "Done", "type": "checkbox" },
            { "name": "notes", "label": "Notes", "type": "multiline", "placeholder": "Any extra details..." }
          ]
        },
        {
          "component": "button",
          "label": "Add Task",
          "onClick": [
            {
              "action": "submit",
              "dataSource": "tasksStore",
              "target": "addTaskForm"
            },
            {
              "action": "navigate",
              "target": "viewTasksPage"
            }
          ],
          "styleHint": { "emphasis": "primary" }
        }
      ]
    },
    "viewTasksPage": {
      "component": "page",
      "title": "My Tasks",
      "content": [
        {
          "component": "text",
          "content": "All your tasks are listed below.",
          "styleHint": { "variant": "body" }
        },
        {
          "component": "list",
          "dataSource": "tasksReader",
          "columns": [
            { "header": "Task", "field": "taskName" },
            { "header": "Due Date", "field": "dueDate", "sortable": true },
            { "header": "Priority", "field": "priority", "sortable": true },
            { "header": "Done", "field": "done", "sortable": true }
          ]
        },
        {
          "component": "button",
          "label": "Add a Task",
          "onClick": [
            {
              "action": "navigate",
              "target": "addTaskPage"
            }
          ],
          "styleHint": { "emphasis": "primary" }
        },
        {
          "component": "button",
          "label": "Mark a Task Done",
          "onClick": [
            {
              "action": "navigate",
              "target": "updateTaskPage"
            }
          ],
          "styleHint": { "emphasis": "secondary" }
        }
      ]
    },
    "updateTaskPage": {
      "component": "page",
      "title": "Mark Task Done",
      "content": [
        {
          "component": "text",
          "content": "Type the name of a task and toggle it done. The task name must match exactly.",
          "styleHint": { "variant": "body" }
        },
        {
          "component": "form",
          "id": "updateTaskForm",
          "fields": [
            { "name": "taskName", "label": "Task Name", "type": "text", "required": true, "placeholder": "Enter the exact task name" },
            { "name": "done", "label": "Done", "type": "checkbox", "default": "true" }
          ]
        },
        {
          "component": "button",
          "label": "Update Task",
          "onClick": [
            {
              "action": "update",
              "dataSource": "tasksUpdater",
              "target": "updateTaskForm",
              "matchField": "taskName"
            },
            {
              "action": "navigate",
              "target": "viewTasksPage"
            }
          ],
          "styleHint": { "emphasis": "primary" }
        },
        {
          "component": "button",
          "label": "Back to Tasks",
          "onClick": [
            {
              "action": "navigate",
              "target": "viewTasksPage"
            }
          ],
          "styleHint": { "emphasis": "secondary" }
        }
      ]
    }
  },
  "dataSources": {
    "tasksStore": {
      "url": "local://tasks",
      "method": "POST"
    },
    "tasksReader": {
      "url": "local://tasks",
      "method": "GET",
      "fields": [
        { "name": "taskName", "type": "text" },
        { "name": "dueDate", "type": "date" },
        { "name": "priority", "type": "select" },
        { "name": "done", "type": "checkbox" },
        { "name": "notes", "type": "multiline" }
      ],
      "seedData": [
        {
          "taskName": "Buy groceries",
          "dueDate": "2025-03-10",
          "priority": "High",
          "done": "false",
          "notes": "Milk, eggs, bread, and fruit."
        },
        {
          "taskName": "Read chapter 5",
          "dueDate": "2025-03-12",
          "priority": "Medium",
          "done": "false",
          "notes": "Atomic Habits — chapter on habit stacking."
        },
        {
          "taskName": "Schedule dentist appointment",
          "dueDate": "2025-03-15",
          "priority": "Low",
          "done": "true",
          "notes": ""
        }
      ]
    },
    "tasksUpdater": {
      "url": "local://tasks",
      "method": "PUT"
    }
  },
  "help": {
    "overview": "To-Do List helps you track tasks, set priorities, and mark them done. Add new tasks, view your full list, and toggle tasks complete when you finish them.",
    "pages": {
      "addTaskPage": "Enter a task name (required), optional due date, and notes. Use the dropdown to select a priority (defaults to 'Medium'). Press Add Task to save it.",
      "viewTasksPage": "View all your tasks with their due dates, priorities, and done status. Use the buttons to add new tasks or mark existing ones done.",
      "updateTaskPage": "Type the exact task name and toggle the Done switch, then press Update Task to save the change."
    }
  },
  "settings": {
    "defaultPriority": {
      "label": "Default priority for new tasks",
      "type": "select",
      "options": ["High", "Medium", "Low"],
      "default": "Medium"
    },
    "showNotes": {
      "label": "Show notes column in task list",
      "type": "checkbox",
      "default": "false"
    }
  },
  "tour": [
    {
      "title": "Welcome to To-Do List!",
      "content": "Keep track of everything you need to do. Add tasks, set priorities, and mark them done when you finish."
    },
    {
      "title": "Your Task List",
      "content": "This page shows all your tasks with their due dates, priorities, and done status. The app comes with a few sample tasks to get you started.",
      "page": "viewTasksPage"
    },
    {
      "title": "Add New Tasks",
      "content": "Use this page to create a new task. Give it a name, set a due date and priority, and it starts as not done.",
      "page": "addTaskPage"
    },
    {
      "title": "Mark Tasks Done",
      "content": "When you finish a task, visit Mark Done, type the task name, toggle the switch, and press Update Task.",
      "page": "updateTaskPage"
    }
  ]
}
