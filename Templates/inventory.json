{
  "templateName": "Inventory",
  "description": "Track items, quantities, and locations. See stock levels at a glance with searchable lists, card layout, and low-stock alerts.",
  "icon": "inventory",
  "questions": [
    {
      "id": "appName",
      "label": "What do you want to call your app?",
      "type": "text",
      "required": true,
      "placeholder": "e.g., Equipment Tracker, Pantry List"
    },
    {
      "id": "itemName",
      "label": "What are you tracking?",
      "type": "text",
      "required": true,
      "placeholder": "e.g., Tools, Products, Supplies"
    },
    {
      "id": "fields",
      "label": "What info do you want to track?",
      "type": "field-list",
      "required": true,
      "presets": [
        { "label": "Name",      "name": "name",      "type": "text" },
        { "label": "Category",  "name": "category",  "type": "select", "options": ["General"] },
        { "label": "Location",  "name": "location",  "type": "text" },
        { "label": "Quantity",  "name": "quantity",   "type": "number" },
        { "label": "Min Stock", "name": "minStock",   "type": "number" },
        { "label": "Unit Cost", "name": "unitCost",   "type": "number" },
        { "label": "Notes",     "name": "notes",      "type": "multiline" }
      ]
    },
    {
      "id": "wantChart",
      "label": "Include a chart showing items by category?",
      "type": "checkbox",
      "default": false
    },
    {
      "id": "chartField",
      "label": "Chart: group by which field?",
      "type": "field-ref",
      "ref": "fields"
    }
  ],
  "template": {
    "appName": "${appName}",
    "startPage": "listPage",
    "menu": [
      { "label": "${itemName}", "mapsTo": "listPage" },
      { "label": "Add ${itemName}", "mapsTo": "addPage" }
    ],
    "pages": {
      "addPage": {
        "component": "page",
        "title": "Add ${itemName}",
        "content": [
          {
            "component": "text",
            "content": "Add a new ${itemName} to your inventory.",
            "styleHint": { "variant": "body" }
          },
          {
            "component": "form",
            "id": "addForm",
            "fields": {
              "$map": "fields",
              "each(field)": {
                "name": "${field.name}",
                "label": "${field.label}",
                "type": "${field.type}",
                "$if": "field.type == 'select'",
                "then": {
                  "name": "${field.name}",
                  "label": "${field.label}",
                  "type": "select",
                  "options": { "$eval": "field.options" }
                },
                "else": {
                  "name": "${field.name}",
                  "label": "${field.label}",
                  "type": "${field.type}"
                }
              }
            }
          },
          {
            "component": "button",
            "label": "Save",
            "onClick": [
              { "action": "submit", "dataSource": "itemsStore", "target": "addForm" },
              { "action": "navigate", "target": "listPage" },
              { "action": "showMessage", "message": "${itemName} saved!" }
            ],
            "styleHint": { "emphasis": "primary" }
          }
        ]
      },
      "listPage": {
        "component": "page",
        "title": "${appName}",
        "content": {
          "$flatten": [
            [
              {
                "component": "summary",
                "label": "Total ${itemName}s",
                "value": "{COUNT(itemsReader)}",
                "icon": "inventory"
              },
              {
                "component": "list",
                "dataSource": "itemsReader",
                "searchable": true,
                "displayAs": "cards",
                "columns": {
                  "$map": "fields",
                  "each(field)": {
                    "header": "${field.label}",
                    "field": "${field.name}",
                    "sortable": true
                  }
                },
                "rowActions": [
                  {
                    "label": "Delete",
                    "action": "delete",
                    "dataSource": "itemsDeleter",
                    "matchField": "_id"
                  }
                ],
                "onRowTap": {
                  "action": "navigate",
                  "target": "editPage",
                  "populateForm": "editForm"
                }
              },
              {
                "component": "button",
                "label": "Add ${itemName}",
                "onClick": [{ "action": "navigate", "target": "addPage" }],
                "styleHint": { "emphasis": "primary" }
              }
            ],
            {
              "$if": "wantChart",
              "then": [
                {
                  "component": "chart",
                  "dataSource": "itemsReader",
                  "chartType": "bar",
                  "labelField": "${chartField}",
                  "valueField": "quantity",
                  "title": "${itemName} by ${chartField}"
                }
              ],
              "else": []
            }
          ]
        }
      },
      "editPage": {
        "component": "page",
        "title": "Edit ${itemName}",
        "content": [
          {
            "component": "form",
            "id": "editForm",
            "fields": {
              "$map": "fields",
              "each(field)": {
                "$if": "field.type == 'select'",
                "then": {
                  "name": "${field.name}",
                  "label": "${field.label}",
                  "type": "select",
                  "options": { "$eval": "field.options" }
                },
                "else": {
                  "name": "${field.name}",
                  "label": "${field.label}",
                  "type": "${field.type}"
                }
              }
            }
          },
          {
            "component": "button",
            "label": "Save Changes",
            "onClick": [
              { "action": "update", "dataSource": "itemsUpdater", "target": "editForm", "matchField": "_id" },
              { "action": "navigate", "target": "listPage" }
            ],
            "styleHint": { "emphasis": "primary" }
          },
          {
            "component": "button",
            "label": "Back",
            "onClick": [{ "action": "navigate", "target": "listPage" }],
            "styleHint": { "emphasis": "secondary" }
          }
        ]
      }
    },
    "dataSources": {
      "itemsStore": {
        "url": "local://inventory",
        "method": "POST"
      },
      "itemsReader": {
        "url": "local://inventory",
        "method": "GET",
        "fields": {
          "$map": "fields",
          "each(field)": {
            "name": "${field.name}",
            "type": "${field.type}"
          }
        }
      },
      "itemsUpdater": {
        "url": "local://inventory",
        "method": "PUT"
      },
      "itemsDeleter": {
        "url": "local://inventory",
        "method": "DELETE"
      }
    },
    "help": {
      "overview": "${appName} helps you manage your ${itemName} inventory. Track quantities, locations, and costs. Add new items, edit existing ones, and delete what you no longer need. All data stays on your device."
    }
  }
}