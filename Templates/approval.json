{
  "templateName": "Approval / Request",
  "description": "Submit requests and track approvals. Reviewers can approve or reject with color-coded status and toast notifications.",
  "icon": "assignment",
  "questions": [
    {
      "id": "appName",
      "label": "What do you want to call your app?",
      "type": "text",
      "required": true,
      "placeholder": "e.g., Leave Requests, Purchase Approvals"
    },
    {
      "id": "requestName",
      "label": "What's being requested?",
      "type": "text",
      "required": true,
      "placeholder": "e.g., Leave, Purchase, Support Ticket"
    },
    {
      "id": "fields",
      "label": "What info does each request need?",
      "type": "field-list",
      "required": true,
      "presets": [
        { "label": "Title", "name": "title", "type": "text" },
        { "label": "Requested By", "name": "requestedBy", "type": "text" },
        { "label": "Date", "name": "date", "type": "date" },
        { "label": "Priority", "name": "priority", "type": "select", "options": ["Low", "Medium", "High"] },
        { "label": "Description", "name": "description", "type": "multiline" },
        { "label": "Amount", "name": "amount", "type": "number" }
      ]
    },
    {
      "id": "wantChart",
      "label": "Include a chart showing requests by status?",
      "type": "checkbox",
      "default": false
    }
  ],
  "template": {
    "appName": "${appName}",
    "startPage": "dashboardPage",
    "menu": [
      { "label": "Dashboard", "mapsTo": "dashboardPage" },
      { "label": "Submit Request", "mapsTo": "submitPage" }
    ],
    "pages": {
      "submitPage": {
        "component": "page",
        "title": "Submit ${requestName} Request",
        "content": [
          {
            "component": "text",
            "content": "Submit a new ${requestName} request.",
            "styleHint": { "variant": "body" }
          },
          {
            "component": "form",
            "id": "submitForm",
            "fields": {
              "$flatten": [
                {
                  "$map": "fields",
                  "each(field)": {
                    "$if": "field.type == 'select'",
                    "then": {
                      "name": "${field.name}",
                      "label": "${field.label}",
                      "type": "select",
                      "options": { "$eval": "field.options" }
                    },
                    "else": {
                      "name": "${field.name}",
                      "label": "${field.label}",
                      "type": "${field.type}"
                    }
                  }
                },
                [
                  {
                    "name": "status",
                    "type": "hidden",
                    "default": "Pending"
                  }
                ]
              ]
            }
          },
          {
            "component": "button",
            "label": "Submit Request",
            "onClick": [
              { "action": "submit", "dataSource": "requestsStore", "target": "submitForm" },
              { "action": "navigate", "target": "thankYouPage" },
              { "action": "showMessage", "message": "${requestName} submitted!" }
            ],
            "styleHint": { "emphasis": "primary" }
          }
        ]
      },
      "thankYouPage": {
        "component": "page",
        "title": "Request Submitted",
        "content": [
          {
            "component": "text",
            "content": "Your ${requestName} request has been submitted and is pending review.",
            "styleHint": { "variant": "subheading" }
          },
          {
            "component": "button",
            "label": "Submit Another",
            "onClick": [{ "action": "navigate", "target": "submitPage" }],
            "styleHint": { "emphasis": "secondary" }
          },
          {
            "component": "button",
            "label": "View All Requests",
            "onClick": [{ "action": "navigate", "target": "dashboardPage" }],
            "styleHint": { "emphasis": "primary" }
          }
        ]
      },
      "dashboardPage": {
        "component": "page",
        "title": "${appName}",
        "content": {
          "$flatten": [
            [
              {
                "component": "summary",
                "label": "Total Requests",
                "value": "{COUNT(requestsReader)}",
                "icon": "assignment"
              },
              {
                "component": "summary",
                "label": "Pending Review",
                "value": "{COUNT(requestsReader)}",
                "icon": "schedule"
              },
              {
                "component": "list",
                "dataSource": "requestsReader",
                "searchable": true,
                "rowColorField": "status",
                "rowColorMap": {
                  "Pending": "orange",
                  "Approved": "green",
                  "Rejected": "red"
                },
                "columns": {
                  "$flatten": [
                    {
                      "$map": "fields",
                      "each(field)": {
                        "header": "${field.label}",
                        "field": "${field.name}",
                        "sortable": true
                      }
                    },
                    [
                      {
                        "header": "Status",
                        "field": "status",
                        "sortable": true,
                        "filterable": true
                      }
                    ]
                  ]
                },
                "rowActions": [
                  {
                    "label": "Approve",
                    "action": "update",
                    "dataSource": "requestsUpdater",
                    "matchField": "_id",
                    "values": { "status": "Approved" },
                    "confirm": "Approve this request?"
                  },
                  {
                    "label": "Reject",
                    "action": "update",
                    "dataSource": "requestsUpdater",
                    "matchField": "_id",
                    "values": { "status": "Rejected" },
                    "confirm": "Reject this request?"
                  }
                ],
                "onRowTap": {
                  "action": "navigate",
                  "target": "reviewPage",
                  "populateForm": "reviewForm"
                }
              },
              {
                "component": "button",
                "label": "Submit New Request",
                "onClick": [{ "action": "navigate", "target": "submitPage" }],
                "styleHint": { "emphasis": "primary" }
              }
            ],
            {
              "$if": "wantChart",
              "then": [
                {
                  "component": "chart",
                  "dataSource": "requestsReader",
                  "chartType": "bar",
                  "labelField": "status",
                  "valueField": "status",
                  "title": "Requests by Status"
                }
              ],
              "else": []
            }
          ]
        }
      },
      "reviewPage": {
        "component": "page",
        "title": "Review ${requestName} Request",
        "content": [
          {
            "component": "detail",
            "fromForm": "reviewForm"
          },
          {
            "component": "form",
            "id": "reviewForm",
            "hidden": true,
            "fields": {
              "$flatten": [
                {
                  "$map": "fields",
                  "each(field)": {
                    "$if": "field.type == 'select'",
                    "then": {
                      "name": "${field.name}",
                      "label": "${field.label}",
                      "type": "select",
                      "options": { "$eval": "field.options" }
                    },
                    "else": {
                      "name": "${field.name}",
                      "label": "${field.label}",
                      "type": "${field.type}"
                    }
                  }
                },
                [
                  {
                    "name": "status",
                    "label": "Status",
                    "type": "text"
                  }
                ]
              ]
            }
          },
          {
            "component": "button",
            "label": "Back to Dashboard",
            "onClick": [{ "action": "navigate", "target": "dashboardPage" }],
            "styleHint": { "emphasis": "secondary" }
          }
        ]
      }
    },
    "dataSources": {
      "requestsStore": {
        "url": "local://requests",
        "method": "POST",
        "fields": {
          "$flatten": [
            {
              "$map": "fields",
              "each(field)": {
                "name": "${field.name}",
                "type": "${field.type}"
              }
            },
            [
              {
                "name": "status",
                "type": "text"
              }
            ]
          ]
        }
      },
      "requestsReader": {
        "url": "local://requests",
        "method": "GET",
        "fields": {
          "$flatten": [
            {
              "$map": "fields",
              "each(field)": {
                "name": "${field.name}",
                "type": "${field.type}"
              }
            },
            [
              {
                "name": "status",
                "type": "text"
              }
            ]
          ]
        }
      },
      "requestsUpdater": {
        "url": "local://requests",
        "method": "PUT"
      },
      "requestsDeleter": {
        "url": "local://requests",
        "method": "DELETE"
      }
    },
    "help": {
      "overview": "${appName} lets you submit ${requestName} requests and track their approval status. New requests start as Pending and can be Approved or Rejected from the dashboard. All data stays on your device."
    }
  }
}