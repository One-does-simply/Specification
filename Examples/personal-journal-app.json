{
  "appName": "Personal Journal",
  "startPage": "writeEntryPage",
  "menu": [
    { "label": "Write Entry", "mapsTo": "writeEntryPage" },
    { "label": "View Entries", "mapsTo": "viewEntriesPage" }
  ],
  "pages": {
    "writeEntryPage": {
      "component": "page",
      "title": "Write a Journal Entry",
      "content": [
        {
          "component": "text",
          "content": "Take a moment to reflect on your day. Write freely and honestly.",
          "styleHint": { "variant": "body" }
        },
        {
          "component": "form",
          "id": "journalEntryForm",
          "fields": [
            { "name": "title", "label": "Title", "type": "text", "required": true, "placeholder": "e.g., Monday Reflections" },
            { "name": "date", "label": "Date & Time", "type": "datetime", "required": true, "default": "NOW" },
            { "name": "mood", "label": "Mood", "type": "select", "options": ["Happy", "Calm", "Grateful", "Anxious", "Sad", "Neutral", "Excited", "Focused", "Stressed"] },
            { "name": "entry", "label": "Journal Entry", "type": "multiline", "required": true, "placeholder": "What's on your mind today?" }
          ]
        },
        {
          "component": "button",
          "label": "Save Entry",
          "onClick": [
            {
              "action": "submit",
              "dataSource": "journalStore",
              "target": "journalEntryForm"
            },
            {
              "action": "navigate",
              "target": "viewEntriesPage"
            }
          ],
          "styleHint": { "emphasis": "primary" }
        },
        {
          "component": "button",
          "label": "Discard",
          "onClick": [
            {
              "action": "navigate",
              "target": "viewEntriesPage"
            }
          ],
          "styleHint": { "emphasis": "danger" }
        }
      ]
    },
    "viewEntriesPage": {
      "component": "page",
      "title": "My Journal Entries",
      "content": [
        {
          "component": "text",
          "content": "{COUNT(journalReader)} journal entries",
          "styleHint": { "variant": "subheading" }
        },
        {
          "component": "text",
          "content": "No entries yet. Write your first journal entry to begin your journey!",
          "styleHint": { "variant": "body" },
          "visibleWhen": { "source": "journalReader", "countEquals": 0 }
        },
        {
          "component": "list",
          "dataSource": "journalReader",
          "columns": [
            { "header": "Date", "field": "date", "sortable": true },
            { "header": "Title", "field": "title" },
            { "header": "Mood", "field": "mood", "sortable": true, "filterable": true }
          ],
          "onRowTap": {
            "action": "navigate",
            "target": "editEntryPage",
            "populateForm": "editEntryForm"
          }
        },
        {
          "component": "button",
          "label": "Write New Entry",
          "onClick": [
            {
              "action": "navigate",
              "target": "writeEntryPage"
            }
          ],
          "styleHint": { "emphasis": "primary" }
        }
      ]
    },
    "editEntryPage": {
      "component": "page",
      "title": "View / Edit Entry",
      "content": [
        {
          "component": "form",
          "id": "editEntryForm",
          "fields": [
            { "name": "title", "label": "Title", "type": "text", "required": true },
            { "name": "date", "label": "Date & Time", "type": "datetime", "required": true },
            { "name": "mood", "label": "Mood", "type": "select", "options": ["Happy", "Calm", "Grateful", "Anxious", "Sad", "Neutral", "Excited", "Focused", "Stressed"] },
            { "name": "entry", "label": "Journal Entry", "type": "multiline", "required": true }
          ]
        },
        {
          "component": "button",
          "label": "Save Changes",
          "onClick": [
            {
              "action": "update",
              "dataSource": "journalUpdater",
              "target": "editEntryForm",
              "matchField": "_id"
            },
            {
              "action": "navigate",
              "target": "viewEntriesPage"
            }
          ],
          "styleHint": { "emphasis": "primary" }
        },
        {
          "component": "button",
          "label": "Back to Entries",
          "onClick": [
            {
              "action": "navigate",
              "target": "viewEntriesPage"
            }
          ],
          "styleHint": { "emphasis": "secondary" }
        }
      ]
    }
  },
  "dataSources": {
    "journalStore": {
      "url": "local://journal_entries",
      "method": "POST"
    },
    "journalUpdater": {
      "url": "local://journal_entries",
      "method": "PUT"
    },
    "journalReader": {
      "url": "local://journal_entries",
      "method": "GET",
      "fields": [
        { "name": "title", "type": "text" },
        { "name": "date", "type": "datetime" },
        { "name": "mood", "type": "select" },
        { "name": "entry", "type": "multiline" }
      ],
      "seedData": [
        {
          "title": "A Fresh Start",
          "date": "2025-03-01 08:30",
          "mood": "Excited",
          "entry": "Today I decided to start journaling regularly. I feel hopeful about building this new habit and reflecting on my days more intentionally."
        },
        {
          "title": "Rainy Afternoon Thoughts",
          "date": "2025-03-02 14:15",
          "mood": "Calm",
          "entry": "Spent the afternoon reading while it rained outside. There is something peaceful about the sound of rain against the window. Finished two chapters of my book."
        }
      ]
    }
  },
  "help": {
    "overview": "Personal Journal is your private space to write daily reflections. Capture your thoughts, track your mood, and look back on past entries anytime. Tap any entry in the list to view or edit it.",
    "pages": {
      "writeEntryPage": "Give your entry a title, pick the date and time, select your current mood from the dropdown, and write your journal text. Press Save Entry when finished, or Discard to go back without saving.",
      "viewEntriesPage": "This page lists all your saved journal entries. Tap any row to open it for viewing or editing. Filter by mood using the dropdown above the table.",
      "editEntryPage": "View and edit a journal entry. Make your changes and press Save Changes, or tap Back to return without saving."
    }
  },
  "tour": [
    {
      "title": "Welcome to Your Journal",
      "content": "Journaling helps reduce stress, improve self-awareness, and track personal growth. This app keeps your entries private and stored locally on your device."
    },
    {
      "title": "Write an Entry",
      "content": "Give each entry a title, pick the date and time, choose your mood from the dropdown, and write whatever is on your mind. Fields marked with * are required.",
      "page": "writeEntryPage"
    },
    {
      "title": "Review & Edit Entries",
      "content": "Browse your previous entries and tap any row to open it for viewing or editing. Filter by mood to notice patterns over time.",
      "page": "viewEntriesPage"
    }
  ]
}
