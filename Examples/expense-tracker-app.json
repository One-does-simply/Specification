{
  "appName": "Expense Tracker",
  "startPage": "logExpensePage",
  "menu": [
    { "label": "Log Expense", "mapsTo": "logExpensePage" },
    { "label": "View Expenses", "mapsTo": "viewExpensesPage" }
  ],
  "pages": {
    "logExpensePage": {
      "component": "page",
      "title": "Log an Expense",
      "content": [
        {
          "component": "text",
          "content": "Record a new expense to keep track of your spending.",
          "styleHint": { "variant": "body" }
        },
        {
          "component": "form",
          "id": "expenseForm",
          "fields": [
            { "name": "description", "label": "Description", "type": "text", "required": true, "placeholder": "e.g., Weekly groceries", "validation": { "minLength": 3, "message": "Description must be at least 3 characters" } },
            { "name": "quantity", "label": "Quantity", "type": "number", "required": true, "default": "1", "validation": { "min": 1, "max": 999 } },
            { "name": "unitPrice", "label": "Unit Price", "type": "number", "required": true, "currency": true, "validation": { "min": 0.01, "max": 99999 } },
            { "name": "total", "label": "Total", "type": "number", "currency": true, "formula": "{quantity} * {unitPrice}" },
            { "name": "category", "label": "Category", "type": "select", "options": ["Food", "Transport", "Bills", "Entertainment", "Medical", "Shopping", "Other"] },
            { "name": "otherCategory", "label": "Specify category", "type": "text", "placeholder": "What kind of expense?", "visibleWhen": { "field": "category", "equals": "Other" } },
            { "name": "date", "label": "Date", "type": "date", "required": true, "default": "NOW" }
          ]
        },
        {
          "component": "button",
          "label": "Save Expense",
          "onClick": [
            {
              "action": "submit",
              "dataSource": "expensesStore",
              "target": "expenseForm",
              "confirm": "Save this expense?"
            },
            {
              "action": "navigate",
              "target": "viewExpensesPage"
            }
          ],
          "styleHint": { "emphasis": "primary" }
        },
        {
          "component": "button",
          "label": "View All Expenses",
          "onClick": [
            {
              "action": "navigate",
              "target": "viewExpensesPage"
            }
          ],
          "styleHint": { "emphasis": "secondary" }
        }
      ]
    },
    "viewExpensesPage": {
      "component": "page",
      "title": "My Expenses",
      "content": [
        {
          "component": "text",
          "content": "Total: ${SUM(expensesReader, total)} across {COUNT(expensesReader)} expenses (avg ${AVG(expensesReader, total)})",
          "styleHint": { "variant": "subheading" }
        },
        {
          "component": "text",
          "content": "No expenses recorded yet. Log your first expense to get started!",
          "styleHint": { "variant": "body" },
          "visibleWhen": { "source": "expensesReader", "countEquals": 0 }
        },
        {
          "component": "chart",
          "dataSource": "expensesReader",
          "chartType": "pie",
          "labelField": "category",
          "valueField": "unitPrice",
          "title": "Spending by Category",
          "visibleWhen": { "source": "expensesReader", "countMin": 1 }
        },
        {
          "component": "list",
          "dataSource": "expensesReader",
          "columns": [
            { "header": "Date", "field": "date", "sortable": true, "filterable": true },
            { "header": "Description", "field": "description" },
            { "header": "Qty", "field": "quantity" },
            { "header": "Unit Price", "field": "unitPrice", "sortable": true, "currency": true },
            { "header": "Total", "field": "total", "sortable": true, "currency": true },
            { "header": "Category", "field": "category", "sortable": true, "filterable": true }
          ],
          "summary": [
            { "column": "total", "function": "sum", "label": "Total Spent" },
            { "column": "total", "function": "avg", "label": "Average" },
            { "column": "total", "function": "count", "label": "Expenses" }
          ]
        },
        {
          "component": "button",
          "label": "Log Another Expense",
          "onClick": [
            {
              "action": "navigate",
              "target": "logExpensePage"
            }
          ],
          "styleHint": { "emphasis": "primary" }
        }
      ]
    }
  },
  "dataSources": {
    "expensesStore": {
      "url": "local://expenses",
      "method": "POST"
    },
    "expensesReader": {
      "url": "local://expenses",
      "method": "GET",
      "fields": [
        { "name": "description", "type": "text" },
        { "name": "quantity", "type": "number" },
        { "name": "unitPrice", "type": "number" },
        { "name": "total", "type": "number", "formula": "{quantity} * {unitPrice}" },
        { "name": "category", "type": "select" },
        { "name": "otherCategory", "type": "text" },
        { "name": "date", "type": "date" }
      ],
      "seedData": [
        {
          "description": "Weekly groceries",
          "quantity": "1",
          "unitPrice": "62",
          "category": "Food",
          "date": "2025-03-01"
        },
        {
          "description": "Monthly bus pass",
          "quantity": "1",
          "unitPrice": "45",
          "category": "Transport",
          "date": "2025-03-01"
        },
        {
          "description": "Coffee with a friend",
          "quantity": "2",
          "unitPrice": "4",
          "category": "Food",
          "date": "2025-03-02"
        },
        {
          "description": "Movie tickets",
          "quantity": "2",
          "unitPrice": "12",
          "category": "Entertainment",
          "date": "2025-03-03"
        }
      ]
    }
  },
  "help": {
    "overview": "Expense Tracker helps you monitor your personal spending. Log each expense with a description, quantity, unit price, category, and date. The total is calculated automatically. A pie chart on the View Expenses page shows spending by category.",
    "pages": {
      "logExpensePage": "Enter a description (at least 3 characters), quantity, and unit price — the total is computed for you. Pick a category; if you choose 'Other', a text field appears to specify. Validation ensures amounts are in range.",
      "viewExpensesPage": "This page shows a pie chart of spending by category and a table of all expenses. The Total column is computed from Quantity x Unit Price for each row. Use the Category and Date dropdowns to filter. Summary totals appear below the table."
    }
  },
  "settings": {
    "currency": {
      "label": "Currency symbol",
      "type": "text",
      "default": "$"
    },
    "defaultCategory": {
      "label": "Default category for new expenses",
      "type": "select",
      "options": ["Food", "Transport", "Bills", "Entertainment", "Medical", "Shopping", "Other"],
      "default": "Food"
    }
  },
  "tour": [
    {
      "title": "Welcome to Expense Tracker",
      "content": "Take control of your finances by logging every expense. This app stores everything locally on your device for privacy."
    },
    {
      "title": "Log Your Spending",
      "content": "Enter a description, quantity, and unit price. The Total field computes automatically. Pick 'Other' for the category and a second field appears to specify. Validation catches out-of-range values before saving.",
      "page": "logExpensePage"
    },
    {
      "title": "Review Your Expenses",
      "content": "See a pie chart breakdown by category and a full data table. Filter by Category or Date, and check the summary row for totals and averages.",
      "page": "viewExpensesPage"
    }
  ]
}
